rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        request.auth.token.email in [
          "acalleb@ups.edu.ec",
          "dalvarezp@ups.edu.ec"
        ];
    }

    match /usuarios/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if false;
    }

    match /predicciones/{predictionId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /prediccionesUsuarios/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if false;
    }

    match /usuariosPrediccionesBrackets/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if false;
    }
  }
}
